# SafeguardAI ML Inference — Environment Variables
# Copy to .env and fill in values

# Model Configuration
MODEL_DIR=/home/venu/Proposals/SafeguardAI/ml/models
DEFAULT_MODEL=audio_mfcc_cnn.tflite

# Server
PORT=8000
WORKERS=2
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Redis (for future rate limiting/caching)
REDIS_URL=redis://redis:6379/0

# Model Registry (optional - for MLflow integration)
MLFLOW_TRACKING_URI=