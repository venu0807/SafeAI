<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground"
    tools:context=".activities.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:translationZ="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="SafeGuard AI"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="?attr/colorPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="96dp">

            <!-- ===== STATUS SHIELD CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <!-- Status Icon with ring -->
                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:id="@+id/status_ring"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:background="@drawable/shield_ring_inactive"
                            android:duplicateParentState="true" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/status_icon"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_shield_off"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shield Dormant"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/status_subtext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tap the switch below to activate"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?android:textColorSecondary" />

                    <!-- Shield Switch -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/protection_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Activate Shield"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== STATS ROW ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio Analysis"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?android:textColorSecondary" />

                        <TextView
                            android:id="@+id/detection_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="samples analyzed"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?android:textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Threat Events"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?android:textColorSecondary" />

                        <TextView
                            android:id="@+id/threat_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                            android:textColor="?attr/colorSecondary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="incidents logged"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?android:textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ===== SECTION: QUICK ACTIONS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="Security Controls"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold" />

            <!-- Safe Timer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_safe_timer"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:text="Dead Man's Switch (Safe Timer)"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:iconGravity="textStart"
                app:iconPadding="16dp" />

            <!-- Emergency Contacts -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_emergency_contacts"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:text="Emergency Contacts"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textStart"
                app:iconPadding="16dp" />

            <!-- Incident Vault -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_incident_vault"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:text="Incident Vault"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_history"
                app:iconGravity="textStart"
                app:iconPadding="16dp" />

            <!-- Guardian Profile -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_profile"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:text="Guardian Profile"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_contact"
                app:iconGravity="textStart"
                app:iconPadding="16dp" />

            <!-- Settings -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_settings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="24dp"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:text="Settings"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart"
                app:iconPadding="16dp" />

            <!-- Battery Optimization -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_battery_bypass"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fix Background Death (Battery Bypass)"
                android:textColor="?attr/colorPrimary"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="?attr/colorPrimary"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1.5dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== SOS FAB ===== -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_panic_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Trigger Immediate Alarm"
        android:src="@drawable/ic_panic"
        android:text="SOS"
        android:textColor="@color/white"
        app:backgroundTint="?attr/colorSecondary"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_panic"
        app:iconTint="@color/white"
        app:rippleColor="@color/accent_container" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
